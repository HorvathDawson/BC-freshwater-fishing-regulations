{
  "name": "bc-fishing-regulations-webapp",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Can I Fish This? - Interactive BC freshwater fishing regulations map",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/prerender.mjs",
    "build:staging": "tsc -b && vite build --mode staging && node scripts/prerender.mjs --mode=staging",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@mapbox/vector-tile": "^2.0.3",
    "@protomaps/basemaps": "^5.7.0",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.563.0",
    "maplibre-gl": "^5.16.0",
    "pbf": "^4.0.1",
    "pmtiles": "^4.3.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.2.4"
  }
}
