# Production: serve pmtiles & data from Cloudflare R2 via Worker (CORS-enabled)
VITE_TILE_BASE_URL=https://bc-fishing-r2.horvath-dawson.workers.dev

# Max prerendered waterbody pages (Cloudflare free tier: 20,000 total files)
# Base Vite output uses ~850 files, so keep this under ~19,150.
PRERENDER_MAX_PAGES=19000
