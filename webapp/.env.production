# Production: serve pmtiles & data from Cloudflare R2 via Worker (CORS-enabled)
VITE_TILE_BASE_URL=https://data.canifishthis.ca

# Max prerendered waterbody pages (Cloudflare free tier: 20,000 total files).
# Base Vite output uses ~850 files (no images in dist/).
# Budget: 20,000 - 850 = ~19,150 safe headroom.
# Set to 0 or remove to render all pages (no cap).
PRERENDER_MAX_PAGES=19000
